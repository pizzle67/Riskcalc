# General configuration.
ENV=DEV
AppName=risk-calculator
ROBLOX_ENVIRONMENT={{env "ROBLOX_ENVIRONMENT"}}
NOMAD_REGION={{env "ROBLOX_REGION"}}
LOGGING_LEVEL=info

SWAGGER_HOST_URL=localhost:22108

# Tracing configuration.
TRACING_ENABLED=false


{{/*# This logic is used to provide a working default apicontrolplane key for local development if your service's isn't ready yet.
# https://go/apicontrolplane-key-templating*/}}
{{- if (secrets "secrets_apps_kv/grc" | contains "APICONTROLPLANE_API_KEY") }}
    {{- with secret "secrets_apps_kv/grc/APICONTROLPLANE_API_KEY" }}
        {{- if (index .Data "risk-calculator") }}
APICONTROLPLANE_API_KEY={{with secret "secrets_apps_kv/grc/APICONTROLPLANE_API_KEY"}}{{index .Data "risk-calculator"}}{{end}}
        {{- else }}
# stubbing api control plane key because service is not yet registered in environment
APICONTROLPLANE_API_KEY=00000000-0000-0000-0000-000000000000
        {{- end }}
    {{- end }}
{{- else }}
# stubbing api control plane key because product is not yet registered in bedev2products
APICONTROLPLANE_API_KEY=00000000-0000-0000-0000-000000000000
{{- end }}
